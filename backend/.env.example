# --- Database (matches docker-compose.yml defaults) ---
DB_URL=jdbc:postgresql://localhost:5432/stockpilot
DB_USERNAME=stockpilot
DB_PASSWORD=stockpilot

# --- JWT (use a long random string, >= 256 bits, in production) ---
JWT_SECRET=change-me-in-prod-this-is-a-dev-secret-that-is-at-least-256-bits-long-000
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# --- Brevo transactional email (OPTIONAL for local dev) ---
# Leave BREVO_API_KEY blank to use the dev fallback: OTP codes and email
# bodies are logged to the application console (labeled [DEV EMAIL FALLBACK])
# instead of being sent, so the full auth flow works with no real account.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@stockpilot.local
BREVO_SENDER_NAME=StockPilot

# --- CORS (frontend origin) ---
CORS_ALLOWED_ORIGIN=http://localhost:5173

# --- Inventory policy: WARN (allow + flag negative stock) or BLOCK ---
APP_INVENTORY_STOCK_POLICY=WARN

# --- Misc ---
APP_DEFAULT_ZONE=Asia/Kolkata
SPRING_PROFILES_ACTIVE=dev
